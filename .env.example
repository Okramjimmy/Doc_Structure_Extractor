# ── App ───────────────────────────────────────────────────────────────────────
APP_TITLE="Doc Structure Extractor"
APP_VERSION="2.0.0"
DEBUG=false

# ── Paths ─────────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
OUTPUT_DIR=output

# ── File limits ───────────────────────────────────────────────────────────────
ALLOWED_EXTENSIONS=[".pdf",".docx",".pptx",".xlsx",".txt"]
MAX_UPLOAD_SIZE_MB=50

# ── Extraction ────────────────────────────────────────────────────────────────
QUESTION_KEYWORDS=["does","is there","has the","have the","are there","can the","will the","should","verify","confirm"]

# ── Job store ─────────────────────────────────────────────────────────────────
# Time (seconds) before completed jobs are purged from memory
JOB_TTL_SECONDS=3600
